{
  "manifest_version": 3,
  "name": "SabdaAI Safety Shield",
  "version": "1.0",
  "description": "Real-time Nepali language safety moderator. Scans and filters offensive or hateful comments on Instagram.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://www.instagram.com/*",
    "https://github.com*/",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.instagram.com/*",
        "http://localhost:8000/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
